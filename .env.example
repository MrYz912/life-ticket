# LifeTicket 环境配置文件示例
# 复制此文件为 .env 并填写实际值

# ===========================================
# 应用配置
# ===========================================
APP_NAME=人生票夹
APP_VERSION=1.0.0

# ===========================================
# iOS 配置
# ===========================================
# Apple Developer Team ID (从 Apple Developer 获取)
IOS_TEAM_ID=YOUR_TEAM_ID

# Bundle Identifier
IOS_BUNDLE_IDENTIFIER=com.lifeticket.app

# Apple ID (用于上传到 App Store)
IOS_APPLE_ID=your-apple-id@email.com

# App Specific Password (从 appleid.apple.com 生成)
IOS_APP_SPECIFIC_PASSWORD=xxxx-xxxx-xxxx-xxxx

# ===========================================
# Android 配置
# ===========================================
# Android Package Name
ANDROID_PACKAGE_NAME=com.lifeticket.app

# Keystore 配置
ANDROID_KEYSTORE_ALIAS=lifeticket
ANDROID_KEYSTORE_PASSWORD=your_keystore_password
ANDROID_KEY_PASSWORD=your_key_password

# Google Play 配置 (可选)
GOOGLE_PLAY_SERVICE_ACCOUNT_JSON=path/to/service-account.json

# ===========================================
# EAS Build 配置 (可选)
# ===========================================
# EAS Project ID
EAS_PROJECT_ID=your-project-id-here

# ===========================================
# 其他配置
# ===========================================
# API 端点 (如果需要)
# API_BASE_URL=https://api.example.com

# 分析工具 (如果需要)
# SENTRY_DSN=https://xxx@sentry.io/xxx
